generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Participant {
  id          String            @id @default(uuid())
  name        String
  createdAt   DateTime          @default(now())
  draws       DrawParticipant[]
  wins        Draw[]            @relation("DrawWinner")
  createdById String?
  createdBy   User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  raffleId    String?
  raffle      Raffle?           @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@map("participants")
}

model Draw {
  id           String            @id @default(uuid())
  winnerId     String?
  winner       Participant?      @relation("DrawWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  participants DrawParticipant[]
  createdAt    DateTime          @default(now())
  createdById  String?
  createdBy    User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  raffleId     String?
  raffle       Raffle?           @relation(fields: [raffleId], references: [id], onDelete: Cascade)

  @@map("draws")
}

model DrawParticipant {
  id            String      @id @default(uuid())
  drawId        String      @map("drawId")
  draw          Draw        @relation(fields: [drawId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([drawId, participantId])
  @@map("draw_participants")
}

model Raffle {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  createdAt   DateTime      @default(now())
  createdById String?
  createdBy   User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  participants Participant[]
  draws        Draw[]

  @@map("raffles")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String?
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  participants Participant[]
  draws        Draw[]
  raffles      Raffle[]

  @@map("users")
}
